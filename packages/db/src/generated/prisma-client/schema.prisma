generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma-client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  USER
}

model User {
  id          String   @id @default(cuid())
  username    String   @unique
  email       String   @unique
  password    String
  phoneNumber String?  @unique
  isVerified  Boolean  @default(false)
  role        Role     @default(USER)
  createdAt   DateTime @default(now())

  categories        Category[]
  expenses          Expense[]
  verificationCodes VerificationCode[]
  monthlyBudgets    MonthlyBudget[]
  categoryBudgets   CategoryBudget[]
}

model Category {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  color     String?
  icon      String?
  isDefault Boolean          @default(false)
  year      Int              @default(0)
  month     Int              @default(0)
  expenses  Expense[]
  budgets   CategoryBudget[]

  @@unique([userId, name, year, month])
}

model Expense {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  amount     Int
  date       DateTime
  note       String?
  createdAt  DateTime @default(now())
}

model VerificationCode {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model MonthlyBudget {
  id              String             @id @default(cuid())
  userId          String
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  year            Int
  month           Int
  startingBalance Int                @default(0)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  allocations     BudgetAllocation[]

  @@unique([userId, year, month])
}

model BudgetAllocation {
  id       String        @id @default(cuid())
  budgetId String
  budget   MonthlyBudget @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  label    String
  amount   Int
  order    Int           @default(0)
}

model CategoryBudget {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  year       Int
  month      Int
  amount     Int

  @@unique([userId, categoryId, year, month])
}
